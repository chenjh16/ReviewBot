# ReviewBot 配置（复制为 .env 后填写）

# ═══ 平台凭证（至少配置一组） ═══

# QQ Bot
QQBOT_APP_ID=your_app_id
QQBOT_APP_SECRET=your_app_secret

# 飞书 Bot（可选，与 QQ Bot 二选一或同时启用）
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# ═══ 服务器 ═══

# HTTP 监听端口（0=自动分配高位端口）
REVIEWBOT_PORT=0

# ═══ Review 行为 ═══

# Agent 提交 review 时的默认超时（秒），Agent 可在请求中覆盖
REVIEW_DEFAULT_TIMEOUT=300

# 单次 review 最大连续超时重试次数，超过后系统自动回复
MAX_CONSECUTIVE_TIMEOUTS=12

# Review 最大存活时间（小时），超过后自动清理
REVIEW_MAX_TTL_HOURS=24

# ═══ 队列与反馈 ═══

# 每个 Agent 的消息队列上限
QUEUE_MAX_PER_AGENT=50

# 反馈聚合静默超时（秒）：用户发送附件后，等待后续消息的最大时间
FEEDBACK_SILENCE_TIMEOUT=300

# ═══ 访问控制 ═══

# 允许的 Reviewer 用户 ID（逗号分隔，留空=允许所有人）
ALLOWED_REVIEWERS=

# ═══ 日志 ═══

# 日志级别：debug / info（默认）/ warn / error
LOG_LEVEL=info

# ═══ 渲染 ═══

# Chrome/Chromium 路径（留空=自动检测）
CHROME_PATH=
